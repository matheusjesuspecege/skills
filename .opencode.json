{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "server": {
    "port": 4096
  },
  "share": "disabled",
    "permission": {
    "edit": "ask",
    "bash": "ask"
  },
   "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "docs/onboarding.md"]
  },
  "mcp": {
    "azure-devops": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp", "pecegeti", "-d", "core", "work-items", "repositories"],
      "enabled": true
    }
  }
}